{
  "name": "xbox-companion",
  "version": "0.2.0-alpha.2",
  "description": "Alpha Decky Loader plugin for ASUS/Lenovo SteamOS handheld controls",
  "author": "Neokura",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "shx rm -rf dist && rollup -c --silent",
    "watch": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "test": "python3 -m unittest",
    "release:zip": "./release.sh"
  },
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.3",
    "@rollup/plugin-commonjs": "^26.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-replace": "^5.0.7",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rollup": "^4.53.5",
    "shx": "^0.3.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@decky/api": "^1.1.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
